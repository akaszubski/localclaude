  localclaude stop               Kill the running server.
  localclaude restart            Restart the last-active profile (inherits allowlist).
  localclaude cc                 Launch claude attached to the active profile.
                                 (Bypasses the multi-env-var copy-paste.)
  localclaude status             Show running model + the claude connect command.
  localclaude list               List cached MLX models on this Mac.
  localclaude doctor             Diagnose the full local-Claude-Code stack.
  localclaude test               End-to-end smoke: real query + garbage detection.
  localclaude -h                 This help.

Flags for \`start\`:
  -allowlist <preset>  See "Allowlist presets" below.
  -bind <host>         Bind vllm-mlx to <host> (default: 127.0.0.1, loopback).
                       Used internally by remote dispatch; rarely set by hand.
  -remote <user@host>  SSH-route this profile to <user@host>. Forces remote
                       dispatch even if the model is cached locally. Useful
                       for sending big jobs to a beefier Mac on demand.

Profiles:
  coder       Qwen3-Coder-30B-A3B-Instruct-4bit       MoE A3B coder, ~120 tok/s
  coder-next  Qwen3-Coder-Next-MLX-8bit                8-bit, best SWE-bench Pass@5
  coder-480   Qwen3-Coder-480B-A35B-Instruct-4bit      ~250GB; top SWE-bench Pro
                                                        (M3 Ultra-class RAM only)
  instruct    Qwen3-30B-A3B-Instruct-2507-4bit         general MoE baseline
  qwen36      Qwen3.6-35B-A3B-8bit                     newest 35B-A3B MoE, agentic-coding tuned
  gemma4      gemma-4-31b-it-4bit                      Google dense 31B (cached)

Allowlist presets (controls how aggressively the optimizer drops tools):
  minimal           Read,Edit,Bash,Grep,Glob,Write           ~99.5% reduction.
                                                              File ops + shell only.
  code   (default)  33 Claude Code natives + searxng MCP     ~98% reduction.
                                                              Full agentic toolkit
                                                              + local web research
                                                              via mcp__searxng__*.
                                                              WebSearch/WebFetch
                                                              dropped (no-ops vs
                                                              local server) so the
                                                              model uses MCP. Other
                                                              MCP servers excluded.
  all               <no filter — all 274+ tools pass through> Slowest first prefill
                                                              (~50s for 80k tokens),
                                                              every MCP tool available.

Examples:
  localclaude start coder                       # default: full Claude Code natives, fast
  localclaude start coder -allowlist all        # add all MCP tools (Gmail, HF, etc), slow
  localclaude start coder -allowlist minimal    # bare-bones, fastest prefill
  localclaude start coder-480 -remote user@m3   # any profile → remote (one-shot)

Remote routing:
  Any profile can run on a different Mac via SSH. Three ways to set the host
  (precedence: CLI > profile slot > generic env var):
    1. CLI:           localclaude start <profile> -remote user@host
    2. Profile slot:  export LOCALCLAUDE_CODER_480_REMOTE=user@host  (coder-480 only)
    3. Generic:       export LOCALCLAUDE_REMOTE=user@host            (all profiles)

  The remote needs:
    - localclaude on PATH (default probe checks ~/Dev/localclaude,
      ~/Dev/local-claude-code-mlx/localclaude, ~/.local/bin, /opt/homebrew/bin,
      /usr/local/bin; override with LOCALCLAUDE_REMOTE_PATH_PREFIX).
    - vllm-mlx installed (the remote runs the model — not this Mac).
    - The model weights cached, OR enough disk for an automatic HF download.
    - SSH key auth from this Mac (BatchMode is non-interactive).

  Opt out of remote routing entirely: export LOCALCLAUDE_NO_REMOTE=1

Only ONE server runs at a time. \`start\` always stops any existing
vllm-mlx on port $PORT first, so you'll never accidentally have two running.
USAGE
}

# ── Stop (also clears the active marker, and remote/tunnel if set) ────
do_stop() {
    # If the active marker says this is a remote profile, stop the remote
    # server and close the local tunnel BEFORE touching the port.
    local remote_host=""
    if [[ -f "$ACTIVE" ]]; then
        # shellcheck disable=SC1090
        . "$ACTIVE" 2>/dev/null || true
    fi
    if [[ -n "${remote_host:-}" ]]; then
        echo "Active profile is remote ($remote_host) — stopping there first…"
        _remote_exec "$remote_host" "localclaude stop" 2>&1 | sed 's/^/  /' || true
        _close_tunnel
        rm -f "$ACTIVE"
        return 0
    fi

    local pid
    pid=$(lsof -nP -iTCP:$PORT -sTCP:LISTEN 2>/dev/null | awk 'NR==2 {print $2}' || true)
    if [[ -z "${pid:-}" ]]; then
        echo "Nothing listening on port $PORT."
        rm -f "$ACTIVE"
        return 0
    fi
    local cmd
    cmd=$(ps -p "$pid" -o command= 2>/dev/null | head -c 80 || echo "(unknown)")
    echo "Stopping PID $pid ($cmd)…"
    kill "$pid" 2>/dev/null || true
    for i in 1 2 3 4 5; do
        sleep 1
        if ! lsof -nP -iTCP:$PORT -sTCP:LISTEN >/dev/null 2>&1; then
            break
        fi
    done
    if lsof -nP -iTCP:$PORT -sTCP:LISTEN >/dev/null 2>&1; then
        echo "Port still held — sending SIGKILL…"
        kill -9 "$pid" 2>/dev/null || true
        sleep 1
    fi
    echo "✓ Port $PORT free."
    rm -f "$ACTIVE"
}

# ── Print the claude connect block ────────────────────────────────
print_connect() {
    local model="$1"
    local context_window="${2:-}"
    local bind_host="${3:-127.0.0.1}"
    local host_in_url="$bind_host"
    if [[ "$bind_host" == "127.0.0.1" || "$bind_host" == "localhost" ]]; then
        host_in_url="localhost"
    fi
    local extra_env=""
    if [[ -n "$context_window" ]]; then
        extra_env=" CLAUDE_CODE_AUTO_COMPACT_WINDOW=$context_window"
    fi
    cat <<CONNECT

To connect Claude Code from a project directory:

    localclaude cc                   # easiest — sets all env vars + runs claude

Or manually (single line):

    ANTHROPIC_BASE_URL=http://$host_in_url:$PORT ANTHROPIC_API_KEY=not-needed ANTHROPIC_MODEL=$model$extra_env claude

When done, kill the server:

    localclaude stop

CONNECT
}

# ── Status ────────────────────────────────────────────────────────
do_status() {
    local pid_on_port
    pid_on_port=$(lsof -nP -iTCP:$PORT -sTCP:LISTEN 2>/dev/null | awk 'NR==2 {print $2}' || true)

    if [[ ! -f "$ACTIVE" ]]; then
        if [[ -n "${pid_on_port:-}" ]]; then
            echo "No active profile recorded, but port $PORT is held by PID $pid_on_port:"
            ps -p "$pid_on_port" -o pid,user,command 2>/dev/null | head -2
            echo
            echo "If this is a stale vllm-mlx, run: localclaude stop"
        else
            echo "No server running. Start one with:  localclaude start <profile>"
        fi
        return 0
    fi

    # shellcheck disable=SC1090
    source "$ACTIVE"

    if [[ -z "${pid_on_port:-}" ]]; then
        echo "Active profile recorded ($profile) but no server on port $port."
        echo "Restart:  localclaude restart"
        return 1
    fi

    echo "Active profile : $profile"
    echo "Model          : $model"
    echo "Port           : $port (PID $pid_on_port)"
    echo "Started        : $started"
    echo "Log            : $log"
    echo
    echo "── Recent optimizer + gate fires ──"
    grep -E "OPTIMIZER|thinking-gate|thinking-leak" "$log" 2>/dev/null | tail -4 || echo "(none yet)"
    echo
    echo "── Recent throughput ──"
    grep -E "Anthropic messages|first token after" "$log" 2>/dev/null | tail -4 || echo "(no requests yet)"
    print_connect "$model" "${context_window:-}" "${bind_host:-127.0.0.1}"
}

# ── Start ─────────────────────────────────────────────────────────
do_start() {
    local profile=""
    local allowlist_preset="code"   # default: tight allowlist for fast prefill
    local bind_host="127.0.0.1"     # default: loopback (LAN-safe)
    local remote_override=""        # set by --remote, overrides profile slot
    local remote_explicit=0         # 1 when --remote was passed (forces dispatch)

    # Parse args: profile name + optional flags. Order doesn't matter.
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -allowlist|--allowlist)
                allowlist_preset="${2:-}"
                shift 2
                ;;
            -all|--all)
                allowlist_preset="all"
                shift
                ;;
            -bind|--bind)
                bind_host="${2:-}"
                shift 2
                ;;
            -remote|--remote)
                remote_override="${2:-}"
                remote_explicit=1
                shift 2
                ;;
            -*)
                echo "Unknown flag: $1" >&2
                echo "Available flags: -allowlist <code|all>  -bind <host>  -remote <user@host>" >&2
                return 1
                ;;
            *)
                if [[ -z "$profile" ]]; then
                    profile="$1"
                else
                    echo "Unexpected extra arg: $1" >&2
                    return 1
                fi
                shift
                ;;
        esac
    done

    # No profile? Try restart of last-active.
    if [[ -z "$profile" ]]; then
        if [[ -f "$ACTIVE" ]]; then
            # shellcheck disable=SC1090
            source "$ACTIVE"
            echo "No profile given — restarting last: $profile (allowlist=${allowlist:-code})"
            # Inherit last-used allowlist if none given on this invocation
            [[ "$allowlist_preset" == "code" && -n "${allowlist:-}" ]] && allowlist_preset="$allowlist"
        else
            echo "Specify a profile:  localclaude start <profile>" >&2
            echo "Run 'localclaude -h' for the list." >&2
            return 1
        fi
    fi

    local resolved
    resolved=$(profile_resolve "$profile") || {
        echo "Unknown profile: $profile" >&2
        echo "Run 'localclaude -h' for profiles, or 'localclaude list' for cached models." >&2
        return 1
    }
    local model tool_parser reasoning_parser context_window remote_host
    IFS='|' read -r model tool_parser reasoning_parser context_window remote_host <<<"$resolved"

    # ── Resolve remote host (precedence: CLI flag > profile slot > generic env) ──
    # --remote on the command line wins. Otherwise honour the profile's own
    # remote slot (e.g. LOCALCLAUDE_CODER_480_REMOTE for coder-480). Finally,
    # fall back to LOCALCLAUDE_REMOTE so any profile can be routed without
    # editing the script.
    if [[ -n "$remote_override" ]]; then
        remote_host="$remote_override"
    elif [[ -z "$remote_host" ]]; then
        remote_host="${LOCALCLAUDE_REMOTE:-}"
    fi

    # ── Single-Mac safety check for big-model profiles ────────────
    # If the profile resolves to a model that exceeds this Mac's RAM and
    # there's no remote host configured, bail clearly rather than silently
    # OOM'ing during the load.
    case "$profile" in
        coder-480)
            local ram_gb
            ram_gb=$(($(sysctl -n hw.memsize) / 1024 / 1024 / 1024))
            if (( ram_gb < 256 )) && [[ -z "$remote_host" ]] && ! _is_model_cached "$model"; then
                cat >&2 <<EOF
✗ Profile '$profile' needs ~250 GB of RAM (or a remote that has it).
   This Mac has ${ram_gb} GB. Three ways to use this profile:

     1. (one-shot) localclaude start coder-480 -remote user@m3-host
        Pass --remote on the CLI; routes this run to that Mac.

     2. (persistent) export LOCALCLAUDE_CODER_480_REMOTE=user@m3-host
        in your ~/.zshrc — every coder-480 start uses that host.
        Or set LOCALCLAUDE_REMOTE=user@host as a default for ALL profiles.

     3. (single-Mac) Use a smaller profile: \`coder\` (30B), \`coder-next\`
        (32B 8-bit) or \`qwen36\` (35B). See \`localclaude -h\`.

   To opt out of remote routing entirely (force local-only behaviour):
     export LOCALCLAUDE_NO_REMOTE=1
EOF
                return 1
            fi
            ;;
    esac

    # ── Remote dispatch ───────────────────────────────────────────
    # If a remote host is set AND we aren't already running on the remote
    # (LOCALCLAUDE_NO_REMOTE prevents recursion), bounce to the remote and
    # connect directly over the network. We bind the remote server on its
    # own IP (extracted from the SSH host), so callers on the same mesh can
    # hit it directly without a tunnel.
    #
    # Cache check: when the remote came from a profile slot or env var, we
    # only dispatch if the model ISN'T cached locally — that way, a fresh
    # local download "promotes" the profile back to local. With explicit
    # --remote on the CLI, the user is asking for remote routing regardless.
    if [[ -n "$remote_host" ]] && [[ -z "${LOCALCLAUDE_NO_REMOTE:-}" ]] && \
       { [[ "$remote_explicit" == "1" ]] || ! _is_model_cached "$model"; }; then
        # Extract the bare host from user@host
        local remote_ip="${remote_host##*@}"
        echo "Profile $profile resolves to remote: $remote_host"
        echo "Will bind the remote server on $remote_ip:$PORT and connect directly."
        echo

        # Clear any stale local listener (old tunnel from a previous version).
        if lsof -nP -iTCP:$PORT -sTCP:LISTEN >/dev/null 2>&1; then
            echo "Local port $PORT in use — clearing first…"
            do_stop
            echo
        fi

        # Tell the remote to bind on its own mesh IP rather than loopback,
        # so we can reach it directly without an SSH tunnel.
        local remote_cmd="localclaude start $profile -allowlist $allowlist_preset -bind $remote_ip"
        echo "── Remote: $remote_host ──"
        if ! _remote_exec "$remote_host" "$remote_cmd" 2>&1 | sed 's/^/  /'; then
            echo "✗ Remote start failed."
            return 1
        fi

        # Save active marker locally — tracks the remote so `stop` can clean up,
        # and bind_host so `cc` knows where to point ANTHROPIC_BASE_URL.
        cat > "$ACTIVE" <<META
profile=$profile
model=$model
port=$PORT
log=remote://$remote_host
allowlist=$allowlist_preset
context_window=$context_window
bind_host=$remote_ip
remote_host=$remote_host
started=$(date -Iseconds)
META

        echo
        echo "✓ Remote server ready at http://$remote_ip:$PORT"
        print_connect "$model" "$context_window" "$remote_ip"
        return 0
    fi

    # Required dependency check — bail early with a clear error.
    if ! command -v vllm-mlx >/dev/null 2>&1; then
        _fail "vllm-mlx CLI not found on PATH — run \`localclaude doctor\` for details"
        return 1
    fi

    # Soft auto-start: SearXNG is optional but the `code` allowlist references
    # mcp__searxng__*. Try idempotent fixes (orb start, docker compose up -d);
    # never run destructive operations (e.g. docker rm) — print the recipe
    # instead. Skipped on -allowlist all where the user manages MCP themselves.
    if [[ "$allowlist_preset" != "all" ]]; then
        if ! command -v docker >/dev/null 2>&1; then
            :  # docker not installed — user opted out of MCP search; stay silent
        else
            if ! docker info >/dev/null 2>&1; then
                if command -v orb >/dev/null 2>&1; then
                    echo "  OrbStack engine stopped — starting…"
                    if orb start >/dev/null 2>&1; then
                        echo "  ✓ OrbStack engine up"
                    else
                        _warn "OrbStack failed to start — run: orb start"
                    fi
                else
                    _warn "Docker daemon not running — start it for mcp__searxng__* tools"
                fi
            fi

            if docker info >/dev/null 2>&1; then
                local _cstate
                _cstate=$(docker inspect -f '{{.State.Status}}' localclaude-searxng 2>/dev/null || echo "missing")
                case "$_cstate" in
                    running) ;;  # all good
                    missing|exited|created|dead)
                        echo "  SearXNG container not running ($_cstate) — bringing it up…"
                        if (cd "$SEARXNG_MCP_DIR" && docker compose up -d >/dev/null 2>&1); then
                            echo "  ✓ SearXNG up on :$SEARXNG_PORT"
                        else
                            _warn "SearXNG failed to start — check: cd $SEARXNG_MCP_DIR && docker compose up"
                            _warn "   (if exit-127 mount errors: docker rm -f localclaude-searxng && docker compose up -d)"
                        fi
                        ;;
                    *)  # restarting / paused / etc — surface but don't touch
                        _warn "SearXNG container in unexpected state: $_cstate"
                        ;;
                esac
            fi
            echo
        fi
    fi

    # Always stop anything on the port — single-server invariant.
    if lsof -nP -iTCP:$PORT -sTCP:LISTEN >/dev/null 2>&1; then
        echo "Port $PORT in use — stopping existing first…"
        do_stop
        echo
    fi

    # Resolve the allowlist preset to an actual flag value (or none).
    # Each preset is a comma-list of tool names the model is allowed to see.
    # Tools NOT in the list are dropped from the request entirely.
    # All native Claude Code tools have entries in the optimizer's STUBS table,
    # so even the wide presets stay tiny in token count.
    local allowlist_tools=""
    case "$allowlist_preset" in
        minimal)
            # Bare-bones file + shell ops only. ~99.5% reduction.
            allowlist_tools="Read,Edit,Bash,Grep,Glob,Write"
            ;;
        code)
            # Full Claude Code agentic toolkit, minus tools that don't work
            # against a local server, plus the local searxng MCP for real
            # web research:
            #
            # INCLUDED (33 native tools + 2 MCP):
            #   file ops + Bash + Task + TodoWrite + plan mode + worktrees
            #   + cron + monitor + skill/slash + MCP discovery
            #   + mcp__searxng__search + mcp__searxng__fetch
            #
            # EXCLUDED (intentionally):
            #   WebSearch / WebFetch  — server-side Anthropic tools that are
            #     no-ops against vllm-mlx. If the model sees them it tries them
            #     first (training bias), gets 0 results, then either hallucinates
            #     or finally falls through to MCP. Dropping them forces the
            #     model straight to mcp__searxng__* which actually works.
            #   Other MCP servers (Gmail, Calendar, Home Assistant, etc.)
            #     — kept out so prefill stays fast.
            #
            # Total: ~3.5K chars sent in tool definitions vs ~195K with
            # -allowlist all (98% reduction). Tools not registered on the
            # user's machine are silently absent from the request, so naming
            # mcp__searxng__* here is harmless if the user hasn't set up
            # the MCP server.
            allowlist_tools="Read,Edit,Write,Bash,Glob,Grep,Task,TodoWrite,ExitPlanMode,EnterPlanMode,NotebookEdit,BashOutput,KillShell,Skill,SlashCommand,TaskCreate,TaskUpdate,TaskGet,TaskList,TaskOutput,TaskStop,AskUserQuestion,Monitor,PushNotification,EnterWorktree,ExitWorktree,CronCreate,CronDelete,CronList,RemoteTrigger,ListMcpResourcesTool,ReadMcpResourceTool,ToolSearch,mcp__searxng__search,mcp__searxng__fetch"
            ;;
        web)
            # Alias for 'code' — kept for backwards compatibility.
            allowlist_tools="Read,Edit,Write,Bash,Glob,Grep,Task,TodoWrite,ExitPlanMode,EnterPlanMode,NotebookEdit,BashOutput,KillShell,Skill,SlashCommand,TaskCreate,TaskUpdate,TaskGet,TaskList,TaskOutput,TaskStop,AskUserQuestion,Monitor,PushNotification,EnterWorktree,ExitWorktree,CronCreate,CronDelete,CronList,RemoteTrigger,ListMcpResourcesTool,ReadMcpResourceTool,ToolSearch,mcp__searxng__search,mcp__searxng__fetch"
            ;;
        all|off|none)
            allowlist_tools=""   # don't add the flag — full 274+ tool catalog passes through
            ;;
        *)
            echo "Unknown -allowlist value: $allowlist_preset" >&2
            echo "Try one of: minimal | code | all" >&2
            return 1
            ;;
    esac

    # SSD KV-cache tier — default ON.
    # Persists prefix cache to disk; cold-restart reuses it instead of
    # re-prefilling the system prompt + tool definitions. Default 20 GB cap.
    #
    # Was briefly disabled by default after the writer thread was found to
    # crash on bfloat16 KV caches (which every production model uses; see
    # akaszubski/vllm-mlx#1). The mlx-native safetensors fix landed in
    # akaszubski/vllm-mlx#2 (merged), so the default is back on.
    #
    # Disable explicitly with LOCALCLAUDE_SSD_CACHE_DIR=off.
    local ssd_cache_dir="${LOCALCLAUDE_SSD_CACHE_DIR-$HOME/.localclaude/ssd-cache}"
    if [[ -n "$ssd_cache_dir" && "$ssd_cache_dir" != "off" ]]; then
        mkdir -p "$ssd_cache_dir"
    fi

    # Build args
    local args=(
        serve "$model"
        --host "$bind_host"
        --port "$PORT"
        --continuous-batching
        --enable-auto-tool-choice
        --tool-call-parser "$tool_parser"
        --optimize-prompts
        --optimize-stub-tools
    )
    [[ -n "$reasoning_parser" ]] && args+=(--reasoning-parser "$reasoning_parser")
    [[ -n "$allowlist_tools" ]] && args+=(--optimize-tool-allowlist "$allowlist_tools")
    # Qwen3-Coder ships an upstream chat template that occasionally emits
    # `<function\n` (no `=name`) tool calls, which the parser can't handle.
    # Override with Jan Kessler's community fix from
    # https://github.com/QwenLM/Qwen3-Coder/issues/475 — adds two lines that
    # eliminate the malformed-call mode. Applied at server load time so the
    # HuggingFace cache stays untouched.
    if [[ "$tool_parser" == "qwen3_coder" ]]; then
        args+=(--chat-template "$WORKSPACE_DIR/localclaude/templates/qwen3-coder-fixed.jinja")
    fi
    if [[ -n "$ssd_cache_dir" && "$ssd_cache_dir" != "off" ]]; then
        args+=(--ssd-cache-dir "$ssd_cache_dir" --ssd-cache-max-gb "${LOCALCLAUDE_SSD_CACHE_MAX_GB:-20}")
    fi

    # Experimentation hook: anything in $LOCALCLAUDE_EXTRA_VLLM_ARGS is
    # word-split and appended as additional `vllm-mlx serve` flags. Used to
    # opt into cache features (--warm-prompts, --kv-cache-quantization, ...)
    # without forking the script.
    if [[ -n "${LOCALCLAUDE_EXTRA_VLLM_ARGS:-}" ]]; then
        local extra
        # shellcheck disable=SC2206
        extra=($LOCALCLAUDE_EXTRA_VLLM_ARGS)
        args+=("${extra[@]}")
    fi

    # Prefer the user's local vllm-mlx repo (with optimizer + thinking-gate
    # patches) over any system-wide install. Picking up the local copy means
    # our --optimize-prompts / --reasoning-parser flags actually exist.
    local pythonpath_prefix=""
    if [[ -d "$VLLM_MLX_DIR/vllm_mlx" ]]; then
        pythonpath_prefix="PYTHONPATH=$VLLM_MLX_DIR"
    fi

    # If the model is fully cached, tell huggingface_hub to skip network
    # validation. vllm-mlx otherwise does a HEAD round-trip per shard on
    # every start (~2-3 sec each, up to 3 min for the 480B). HF cache files
    # are content-addressed by SHA, so this is wasted work.
    local hf_offline_prefix=""
    if _is_model_cached "$model"; then
        hf_offline_prefix="HF_HUB_OFFLINE=1"
        echo "  (model is fully cached → setting HF_HUB_OFFLINE=1 to skip HF validation)"
    fi

    local log="$LOG_DIR/$profile.log"

    cat <<INTRO
Starting profile: $profile
  model:            $model
  tool-parser:      $tool_parser
  reasoning-parser: ${reasoning_parser:-<none>}
  allowlist:        $allowlist_preset
  bind:             $bind_host:$PORT
  context-window:   ${context_window:-<unset>} tokens (auto-compact at ~80%)
  log:              $log

INTRO

    # Save active marker
    cat > "$ACTIVE" <<META
profile=$profile
model=$model
port=$PORT
log=$log
allowlist=$allowlist_preset
context_window=$context_window
bind_host=$bind_host
remote_host=
started=$(date -Iseconds)
META

    # Truncate the log so old runs' ERROR lines don't trigger false-positive
    # failure detection in the wait loop below.
    : > "$log"

    # Launch detached. PYTHONPATH and HF_HUB_OFFLINE prefixes (if any) ensure
    # we use the user's local patched repo and skip needless HF validation.
    cd "$VLLM_MLX_DIR" 2>/dev/null || cd "$HOME"
    local env_prefix
    env_prefix=$(printf '%s ' $pythonpath_prefix $hf_offline_prefix | sed 's/ *$//')
    if [[ -n "$env_prefix" ]]; then
        nohup env $env_prefix vllm-mlx "${args[@]}" > "$log" 2>&1 &
    else
        nohup vllm-mlx "${args[@]}" > "$log" 2>&1 &
    fi
    local server_pid=$!
    disown $server_pid 2>/dev/null || true
    echo "server-pid=$server_pid"

    # Wait for ready. Total budget is 5 minutes for already-cached models, but
    # large or freshly-downloading models need more — extend on real activity.
    local STEP_S=5
    local BASE_TIMEOUT_S=300       # 5 min default
    local LONG_LOAD_GRACE_S=900    # extend by 15 min if real download/large load detected
    local deadline=$(( $(date +%s) + BASE_TIMEOUT_S ))
    local extension_announced=0
    local ready=0

    # Pre-flight: if all weights are present locally, this is a "load big
    # model from disk" wait, not a download wait. The HF cache fingerprint is
    # the directory under ~/.cache/huggingface/hub for this model.
    local model_cache_id="models--$(echo "$model" | sed 's|/|--|')"
    _has_incomplete_blob() {
        for base in "$HOME/Models" "$HOME/.cache/huggingface/hub"; do
            if ls "$base/$model_cache_id/blobs/"*.incomplete 2>/dev/null | grep -q .; then
                return 0
            fi
        done
        return 1
    }

    echo "Waiting for model load (up to ${BASE_TIMEOUT_S}s; will extend on real activity)…"
    while :; do
        if grep -q "Application startup complete" "$log" 2>/dev/null; then
            ready=1
            break
        fi
        if grep -qE "ERROR|Traceback|address already in use" "$log" 2>/dev/null; then
            echo
            echo "✗ Server failed. Last 20 log lines:"
            tail -20 "$log"
            return 1
        fi
        # Extend the deadline when we see real activity. Two cases:
        #   1. An incomplete blob exists in the HF cache → live download.
        #   2. The 'Loading model' / 'BatchedEngine loaded' progression has
        #      started → the engine is doing work, just slow on huge weights.
        local kind=""
        if _has_incomplete_blob; then
            kind="downloading"
        elif grep -qE "Loading model|BatchedEngine loaded|Memory-aware cache initialized" "$log" 2>/dev/null \
             && ! grep -q "Application startup complete" "$log" 2>/dev/null; then
            kind="loading large model from cache"
        fi
        if [[ -n "$kind" ]]; then
            if [[ $extension_announced -eq 0 ]]; then
                echo
                echo "  ($kind — extending timeout by ${LONG_LOAD_GRACE_S}s)"
                extension_announced=1
            fi
            deadline=$(( $(date +%s) + LONG_LOAD_GRACE_S ))
        fi
        if (( $(date +%s) >= deadline )); then
            break
        fi
        sleep "$STEP_S"
        printf "."
    done
    echo

    if [[ $ready -ne 1 ]]; then
        echo "⚠ Timed out waiting for model load."
        echo "  The server may still be loading — check:"
        echo "     tail -F $log"
        echo "     localclaude status"
        return 1
    fi

    local ready_host="$bind_host"
    [[ "$bind_host" == "127.0.0.1" ]] && ready_host="localhost"
    echo "✓ Server ready at http://$ready_host:$PORT"
    print_connect "$model" "$context_window" "$bind_host"
}

# ── List cached ───────────────────────────────────────────────────
list_cached() {
    echo "── Cached MLX models in ~/Models/ ──"
    if [[ ! -d "$HOME/Models" ]]; then
        echo "  (no ~/Models directory)"
        return 0
    fi
    find "$HOME/Models" -maxdepth 1 -type d -name "models--*" 2>/dev/null | sort | while read -r d; do
        local mid
        mid=$(basename "$d" | sed -e 's|^models--||' -e 's|--|/|')
        if find "$d/snapshots" -maxdepth 2 -name "*.safetensors" -print -quit 2>/dev/null | grep -q .; then
            local size
            size=$(du -sh "$d" 2>/dev/null | awk '{print $1}')
            printf "  %6s  %s\n" "$size" "$mid"
        fi
    done
}

# ── cc: launch claude attached to the active profile ─────────────
# Reads ~/.localclaude/.active, sets all the env vars (BASE_URL,
# API_KEY, MODEL, AUTO_COMPACT_WINDOW), and exec's `claude` from the
# current directory. Avoids the multi-env-var copy-paste fragility
# where line-wrapping in the terminal eats the env block.
do_cc() {
    if [[ ! -f "$ACTIVE" ]]; then
        echo "No active profile. Start one first: localclaude start <profile>" >&2
        return 1
    fi
    # shellcheck disable=SC1090
    source "$ACTIVE"
    if ! lsof -nP -iTCP:"$port" -sTCP:LISTEN >/dev/null 2>&1; then
        echo "No server on port $port. Start one: localclaude start $profile" >&2
        return 1
    fi
    local extra=()
    [[ -n "${context_window:-}" ]] && extra+=(CLAUDE_CODE_AUTO_COMPACT_WINDOW="$context_window")

    # Avoid running from $HOME (Glob will time out scanning the whole home dir).
    local cwd="$PWD"
    if [[ "$cwd" == "$HOME" ]]; then
        cwd="$VLLM_MLX_DIR"
        echo "(switching cwd to $cwd to avoid Glob timeout in \$HOME)" >&2
    fi
    cd "$cwd"

    local host_in_url="${bind_host:-127.0.0.1}"
    [[ "$host_in_url" == "127.0.0.1" ]] && host_in_url="localhost"

    echo "Launching claude attached to: $profile ($model) on http://$host_in_url:$port"
    echo
    exec env \
        ANTHROPIC_BASE_URL="http://$host_in_url:$port" \
        ANTHROPIC_API_KEY="not-needed" \
        ANTHROPIC_MODEL="$model" \
        "${extra[@]}" \
        claude "$@"
}

# ── Restart shortcut ──────────────────────────────────────────────
do_restart() {
    if [[ ! -f "$ACTIVE" ]]; then
        echo "No last-active profile to restart." >&2
        echo "Pick one:  localclaude start <profile>" >&2
        return 1
    fi
    # shellcheck disable=SC1090
    source "$ACTIVE"
    do_start "$profile"
}

# ── Dispatch ──────────────────────────────────────────────────────
case "${1:-}" in
    ""|-h|--help|help) help ;;
    start)             shift; do_start "$@" ;;
    stop)              do_stop ;;
    restart)           do_restart ;;
    status)            do_status ;;
    list)              list_cached ;;
    doctor|check)      do_doctor ;;
    test)              do_test ;;
    cc|claude)         shift; do_cc "$@" ;;
    *)
        echo "Unknown subcommand: $1" >&2
        help >&2
        exit 1
        ;;
esac
