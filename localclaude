#!/usr/bin/env bash
# localclaude — manage one local vllm-mlx server, print Claude Code connect commands.
#
# Lifecycle:
#   localclaude start <profile>    Kill any existing server, start the chosen profile
#                                  detached, wait for "Application startup complete",
#                                  then print the claude command to run in another terminal.
#   localclaude stop               Kill the running server.
#   localclaude status             Show what's running + the claude connect command.
#   localclaude list               List cached models on this Mac.
#   localclaude restart            Same as start, using last-active profile.
#   localclaude -h                 This help.
#
# Only ONE vllm-mlx server is allowed on port 8000. `start` always kills any
# existing process there before launching, so you can't accidentally run two.

set -euo pipefail

# ── Paths ─────────────────────────────────────────────────────────
# State lives in ~/.localclaude/ so the script itself can live anywhere on PATH.
STATE_HOME="$HOME/.localclaude"
LOG_DIR="$STATE_HOME/logs"
ACTIVE="$STATE_HOME/.active"
PORT=8000
SEARXNG_MCP_DIR="${LOCALCLAUDE_SEARXNG_MCP_DIR:-$HOME/Dev/searxng-mcp}"
SEARXNG_PORT=8080
mkdir -p "$LOG_DIR"

# ── Tiny output helpers ───────────────────────────────────────────
_ok()    { printf "  \033[32m✓\033[0m %s\n" "$1"; }
_warn()  { printf "  \033[33m⚠\033[0m %s\n" "$1"; }
_fail()  { printf "  \033[31m✗\033[0m %s\n" "$1"; }

# ── Dependency checks ─────────────────────────────────────────────
# Each function exits 0 (ok) or 1 (broken). They print a one-liner about
# what they checked. Used by `doctor`, and a subset is run before `start`
# (with non-fatal warnings) so users see problems early.

check_vllm_mlx() {
    if command -v vllm-mlx >/dev/null 2>&1; then
        _ok "vllm-mlx CLI on PATH ($(command -v vllm-mlx))"
        return 0
    fi
    _fail "vllm-mlx CLI not found — install it (pip install vllm-mlx, or clone the fork)"
    return 1
}

check_claude_cli() {
    if command -v claude >/dev/null 2>&1; then
        local ver
        ver=$(claude --version 2>/dev/null | head -1)
        _ok "claude CLI on PATH ($ver)"
        return 0
    fi
    _fail "claude CLI not found — install Claude Code from anthropic.com/claude/code"
    return 1
}

check_local_vllm_mlx_repo() {
    if [[ -d "$HOME/Dev/vllm-mlx/vllm_mlx" ]]; then
        _ok "local vllm-mlx repo at ~/Dev/vllm-mlx (used via PYTHONPATH override)"
        return 0
    fi
    _warn "no ~/Dev/vllm-mlx repo — server will use whatever vllm-mlx is on PATH"
    _warn "  (clone the patched fork for thinking-gate + optimizer features:"
    _warn "   git clone https://github.com/akaszubski/vllm-mlx.git ~/Dev/vllm-mlx)"
    return 1
}

check_docker() {
    if command -v docker >/dev/null 2>&1; then
        if docker info >/dev/null 2>&1; then
            _ok "docker available + daemon running"
            return 0
        fi
        _warn "docker installed but daemon not running (start OrbStack/Docker)"
        return 1
    fi
    _warn "docker CLI not found — needed to run the SearXNG container"
    _warn "  (OrbStack: brew install orbstack; or add ~/.orbstack/bin to PATH)"
    return 1
}

check_searxng_container() {
    if ! command -v docker >/dev/null 2>&1; then
        return 1
    fi
    local cid
    cid=$(docker ps --filter "name=localclaude-searxng" --format '{{.ID}}' 2>/dev/null | head -1)
    if [[ -z "$cid" ]]; then
        _warn "SearXNG container not running — start with: cd $SEARXNG_MCP_DIR && docker compose up -d"
        return 1
    fi
    if curl -sk -o /dev/null -m 3 "http://127.0.0.1:$SEARXNG_PORT/" 2>/dev/null; then
        _ok "SearXNG container up + responding on http://127.0.0.1:$SEARXNG_PORT"
        return 0
    fi
    _warn "SearXNG container is up but not responding on http://127.0.0.1:$SEARXNG_PORT"
    return 1
}

check_searxng_mcp_venv() {
    if [[ ! -x "$SEARXNG_MCP_DIR/run.sh" ]]; then
        _warn "searxng-mcp not installed — clone https://github.com/akaszubski/searxng-mcp to $SEARXNG_MCP_DIR"
        return 1
    fi
    if [[ ! -x "$SEARXNG_MCP_DIR/.venv/bin/python" ]]; then
        _warn "searxng-mcp venv missing — run: cd $SEARXNG_MCP_DIR && python3 -m venv .venv && .venv/bin/pip install mcp httpx"
        return 1
    fi
    if "$SEARXNG_MCP_DIR/.venv/bin/python" -c "import mcp, httpx" 2>/dev/null; then
        _ok "searxng-mcp venv has mcp + httpx"
        return 0
    fi
    _warn "searxng-mcp venv exists but missing deps — run: $SEARXNG_MCP_DIR/.venv/bin/pip install mcp httpx"
    return 1
}

check_mcp_registered() {
    if ! command -v claude >/dev/null 2>&1; then
        return 1
    fi
    # `claude mcp list` exits 0 and prints registered servers; format may
    # change between versions, so just look for the name as a substring.
    if claude mcp list 2>/dev/null | grep -qi "searxng"; then
        _ok "searxng MCP registered with Claude Code"
        return 0
    fi
    _warn "searxng MCP not registered — run: claude mcp add searxng -- $SEARXNG_MCP_DIR/run.sh"
    return 1
}

# ── test: end-to-end smoke against the running model ─────────────
# Issues a real claude --print query that should call mcp__searxng__search
# and return a coherent paragraph. Catches three classes of failure:
#   1. Server not running / SearXNG down
#   2. MCP server can't dispatch tool calls
#   3. Model decoder collapse (4-bit instability, infinite loops, gibberish)
#
# Garbage detection heuristic: if >25% of the response chars are non-ASCII
# in a non-CJK context, OR if the response has too many distinct scripts
# (Latin + Arabic + Han + Hangul mixing is a classic decoder-collapse
# signature), we flag it. Tuned against the failure modes we've seen.

_garbage_score() {
    # Reads stdin, prints two integers: total_chars distinct_scripts.
    # distinct_scripts > 3 is a strong signal of decoder collapse.
    python3 - <<'PY'
import sys, unicodedata
text = sys.stdin.read()
scripts = set()
for ch in text:
    try:
        name = unicodedata.name(ch, "")
    except Exception:
        continue
    for tag in ("LATIN", "ARABIC", "HEBREW", "CJK", "HIRAGANA", "KATAKANA", "HANGUL", "THAI", "DEVANAGARI", "CYRILLIC", "GREEK", "TIBETAN"):
        if tag in name:
            scripts.add(tag)
            break
print(len(text), len(scripts))
PY
}

do_test() {
    local fails=0
    echo "── localclaude test ──────────────────────────────"

    # 1. Server reachable
    if ! curl -sf -o /dev/null -m 3 "http://127.0.0.1:$PORT/v1/models" 2>/dev/null; then
        _fail "Server not responding on http://127.0.0.1:$PORT  (run: localclaude start <profile>)"
        return 1
    fi
    _ok "Server responding on http://127.0.0.1:$PORT"

    # 2. SearXNG backend reachable
    if curl -sf -o /dev/null -m 3 "http://127.0.0.1:$SEARXNG_PORT/" 2>/dev/null; then
        _ok "SearXNG backend up on http://127.0.0.1:$SEARXNG_PORT"
    else
        _warn "SearXNG backend down — search test will be skipped"
    fi

    # 3. claude CLI present
    if ! command -v claude >/dev/null 2>&1; then
        _fail "claude CLI not on PATH"
        return 1
    fi

    # 4. Resolve model from active profile
    if [[ ! -f "$ACTIVE" ]]; then
        _fail "No active profile recorded — start one first"
        return 1
    fi
    # shellcheck disable=SC1090
    source "$ACTIVE"

    # 5. End-to-end query — non-trivial generation that should call MCP search
    echo "Running end-to-end claude --print test (60s timeout)…"
    local out
    out=$(env \
        ANTHROPIC_BASE_URL="http://localhost:$port" \
        ANTHROPIC_API_KEY=not-needed \
        ANTHROPIC_MODEL="$model" \
        claude --print --output-format json \
        --dangerously-skip-permissions \
        --model "$model" \
        "Use the mcp__searxng__search tool to find the official Anthropic Claude Code documentation URL. Quote one result title and URL." 2>&1) || {
        _fail "claude --print failed to run cleanly"
        echo "$out" | head -3
        return 1
    }

    # Parse JSON
    local result tokens turns
    result=$(echo "$out" | python3 -c "import json,sys; d=json.loads(sys.stdin.read()); print(d.get('result',''))" 2>/dev/null) || {
        _fail "Could not parse JSON output from claude --print"
        echo "$out" | head -5
        return 1
    }
    tokens=$(echo "$out" | python3 -c "import json,sys; d=json.loads(sys.stdin.read()); print(d.get('usage',{}).get('output_tokens',0))" 2>/dev/null)
    turns=$(echo "$out" | python3 -c "import json,sys; d=json.loads(sys.stdin.read()); print(d.get('num_turns',0))" 2>/dev/null)

    if [[ -z "$result" ]]; then
        _fail "Model returned empty result (likely thinking-only or generation aborted)"
        return 1
    fi
    _ok "claude --print returned a result: $tokens output tokens in $turns turn(s)"

    # 6. Garbage detection
    local stats total_chars distinct_scripts
    stats=$(printf '%s' "$result" | _garbage_score)
    total_chars=$(echo "$stats" | awk '{print $1}')
    distinct_scripts=$(echo "$stats" | awk '{print $2}')
    if (( distinct_scripts > 3 )); then
        _fail "Decoder collapse: response mixes $distinct_scripts distinct scripts ($total_chars chars). 4-bit instability — try a different profile."
        echo "  preview: $(printf '%s' "$result" | head -c 120)..."
        ((fails++))
    else
        _ok "Response is coherent ($distinct_scripts scripts in $total_chars chars)"
    fi

    # 7. Did the model actually call the search tool?
    if [[ "$turns" -ge 2 ]]; then
        _ok "Multi-turn agent loop completed (turns=$turns) — tool call likely fired"
    else
        _warn "Single-turn response — tool call may not have fired (model answered from training data)"
    fi

    echo
    if (( fails > 0 )); then
        echo "✗ $fails test(s) failed."
        return 1
    fi
    echo "✓ End-to-end test passed."
    echo "  preview: $(printf '%s' "$result" | head -c 200)..."
}

# ── doctor: full diagnostic ───────────────────────────────────────
do_doctor() {
    local fails=0
    echo "── localclaude doctor ────────────────────────────────"
    echo
    echo "Required:"
    check_vllm_mlx || ((fails++))
    check_claude_cli || ((fails++))
    echo
    echo "Recommended (full Claude-Code-on-local-LLM stack):"
    check_local_vllm_mlx_repo || true   # warn-only
    check_docker || true
    check_searxng_container || true
    check_searxng_mcp_venv || true
    check_mcp_registered || true
    echo
    if (( fails > 0 )); then
        echo "✗ $fails required check(s) failed. Fix them before \`start\`."
        return 1
    fi
    echo "✓ Required deps in place. Recommended items above are optional but unlock web research."
    return 0
}

# ── Profile catalog ───────────────────────────────────────────────
profile_resolve() {
    case "$1" in
        coder)       echo "mlx-community/Qwen3-Coder-30B-A3B-Instruct-4bit|qwen3_coder|" ;;
        coder-next)  echo "lmstudio-community/Qwen3-Coder-Next-MLX-8bit|qwen3_coder|" ;;
        # 'opus' (Qwen3.5-27B-Claude-4.6-Opus-Distilled-MLX-4bit) removed:
        # the upload includes vision_tower weights, so vllm-mlx's text engine
        # crashes on the unknown keys. Re-enable if/when a text-only variant
        # ships, or once we route this through --mllm.
        instruct)    echo "mlx-community/Qwen3-30B-A3B-Instruct-2507-4bit|qwen|qwen3" ;;
        qwen36)      echo "mlx-community/Qwen3.6-35B-A3B-4bit|qwen|qwen3" ;;
        gemma4)      echo "mlx-community/gemma-4-31b-it-4bit|gemma4|" ;;
        *) return 1 ;;
    esac
}

