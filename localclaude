# ── Stop (also clears the active marker) ──────────────────────────
do_stop() {
    local pid
    pid=$(lsof -nP -iTCP:$PORT -sTCP:LISTEN 2>/dev/null | awk 'NR==2 {print $2}' || true)
    if [[ -z "${pid:-}" ]]; then
        echo "Nothing listening on port $PORT."
        rm -f "$ACTIVE"
        return 0
    fi
    local cmd
    cmd=$(ps -p "$pid" -o command= 2>/dev/null | head -c 80 || echo "(unknown)")
    echo "Stopping PID $pid ($cmd)…"
    kill "$pid" 2>/dev/null || true
    for i in 1 2 3 4 5; do
        sleep 1
        if ! lsof -nP -iTCP:$PORT -sTCP:LISTEN >/dev/null 2>&1; then
            break
        fi
    done
    if lsof -nP -iTCP:$PORT -sTCP:LISTEN >/dev/null 2>&1; then
        echo "Port still held — sending SIGKILL…"
        kill -9 "$pid" 2>/dev/null || true
        sleep 1
    fi
    echo "✓ Port $PORT free."
    rm -f "$ACTIVE"
}

# ── Print the claude connect block ────────────────────────────────
print_connect() {
    local model="$1"
    cat <<CONNECT

To connect Claude Code (run in another terminal):

    cd ~/Dev/vllm-mlx           # or any project directory you want claude to work in
    ANTHROPIC_BASE_URL=http://localhost:$PORT ANTHROPIC_API_KEY=not-needed ANTHROPIC_MODEL=$model claude

When done, kill the server:

    localclaude stop

CONNECT
}

# ── Status ────────────────────────────────────────────────────────
do_status() {
    local pid_on_port
    pid_on_port=$(lsof -nP -iTCP:$PORT -sTCP:LISTEN 2>/dev/null | awk 'NR==2 {print $2}' || true)

    if [[ ! -f "$ACTIVE" ]]; then
        if [[ -n "${pid_on_port:-}" ]]; then
            echo "No active profile recorded, but port $PORT is held by PID $pid_on_port:"
            ps -p "$pid_on_port" -o pid,user,command 2>/dev/null | head -2
            echo
            echo "If this is a stale vllm-mlx, run: localclaude stop"
        else
            echo "No server running. Start one with:  localclaude start <profile>"
        fi
        return 0
    fi

    # shellcheck disable=SC1090
    source "$ACTIVE"

    if [[ -z "${pid_on_port:-}" ]]; then
        echo "Active profile recorded ($profile) but no server on port $port."
        echo "Restart:  localclaude restart"
        return 1
    fi

    echo "Active profile : $profile"
    echo "Model          : $model"
    echo "Port           : $port (PID $pid_on_port)"
    echo "Started        : $started"
    echo "Log            : $log"
    echo
    echo "── Recent optimizer + gate fires ──"
    grep -E "OPTIMIZER|thinking-gate|thinking-leak" "$log" 2>/dev/null | tail -4 || echo "(none yet)"
    echo
    echo "── Recent throughput ──"
    grep -E "Anthropic messages|first token after" "$log" 2>/dev/null | tail -4 || echo "(no requests yet)"
    print_connect "$model"
}

# ── Start ─────────────────────────────────────────────────────────
do_start() {
    local profile=""
    local allowlist_preset="code"   # default: tight allowlist for fast prefill

    # Parse args: profile name + optional flags. Order doesn't matter.
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -allowlist|--allowlist)
                allowlist_preset="${2:-}"
                shift 2
                ;;
            -all|--all)
                allowlist_preset="all"
                shift
                ;;
            -*)
                echo "Unknown flag: $1" >&2
                echo "Available flags: -allowlist <code|web|all>  -all" >&2
                return 1
                ;;
            *)
                if [[ -z "$profile" ]]; then
                    profile="$1"
                else
                    echo "Unexpected extra arg: $1" >&2
                    return 1
                fi
                shift
                ;;
        esac
    done

    # No profile? Try restart of last-active.
    if [[ -z "$profile" ]]; then
        if [[ -f "$ACTIVE" ]]; then
            # shellcheck disable=SC1090
            source "$ACTIVE"
            echo "No profile given — restarting last: $profile (allowlist=${allowlist:-code})"
            # Inherit last-used allowlist if none given on this invocation
            [[ "$allowlist_preset" == "code" && -n "${allowlist:-}" ]] && allowlist_preset="$allowlist"
        else
            echo "Specify a profile:  localclaude start <profile>" >&2
            echo "Run 'localclaude -h' for the list." >&2
            return 1
        fi
    fi

    local resolved
    resolved=$(profile_resolve "$profile") || {
        echo "Unknown profile: $profile" >&2
        echo "Run 'localclaude -h' for profiles, or 'localclaude list' for cached models." >&2
        return 1
    }
    local model tool_parser reasoning_parser
    IFS='|' read -r model tool_parser reasoning_parser <<<"$resolved"

    # Required dependency check — bail early with a clear error.
    if ! command -v vllm-mlx >/dev/null 2>&1; then
        _fail "vllm-mlx CLI not found on PATH — run \`localclaude doctor\` for details"
        return 1
    fi

    # Soft checks: warn but don't block. Skipped on -allowlist all where
    # the user explicitly opted into having to register MCP themselves.
    if [[ "$allowlist_preset" != "all" ]]; then
        if ! docker ps --filter "name=localclaude-searxng" --format '{{.ID}}' 2>/dev/null | grep -q .; then
            _warn "SearXNG container not running — \`mcp__searxng__*\` tools won't work"
            _warn "   start it with: cd $SEARXNG_MCP_DIR && docker compose up -d"
            _warn "   (or run: localclaude doctor)"
            echo
        fi
    fi

    # Always stop anything on the port — single-server invariant.
    if lsof -nP -iTCP:$PORT -sTCP:LISTEN >/dev/null 2>&1; then
        echo "Port $PORT in use — stopping existing first…"
        do_stop
        echo
    fi

    # Resolve the allowlist preset to an actual flag value (or none).
    # Each preset is a comma-list of tool names the model is allowed to see.
    # Tools NOT in the list are dropped from the request entirely.
    # All native Claude Code tools have entries in the optimizer's STUBS table,
    # so even the wide presets stay tiny in token count.
    local allowlist_tools=""
    case "$allowlist_preset" in
        minimal)
            # Bare-bones file + shell ops only. ~99.5% reduction.
            allowlist_tools="Read,Edit,Bash,Grep,Glob,Write"
            ;;
        code)
            # Full Claude Code agentic toolkit, minus tools that don't work
            # against a local server, plus the local searxng MCP for real
            # web research:
            #
            # INCLUDED (33 native tools + 2 MCP):
            #   file ops + Bash + Task + TodoWrite + plan mode + worktrees
            #   + cron + monitor + skill/slash + MCP discovery
            #   + mcp__searxng__search + mcp__searxng__fetch
            #
            # EXCLUDED (intentionally):
            #   WebSearch / WebFetch  — server-side Anthropic tools that are
            #     no-ops against vllm-mlx. If the model sees them it tries them
            #     first (training bias), gets 0 results, then either hallucinates
            #     or finally falls through to MCP. Dropping them forces the
            #     model straight to mcp__searxng__* which actually works.
            #   Other MCP servers (Gmail, Calendar, Home Assistant, etc.)
            #     — kept out so prefill stays fast.
            #
            # Total: ~3.5K chars sent in tool definitions vs ~195K with
            # -allowlist all (98% reduction). Tools not registered on the
            # user's machine are silently absent from the request, so naming
            # mcp__searxng__* here is harmless if the user hasn't set up
            # the MCP server.
            allowlist_tools="Read,Edit,Write,Bash,Glob,Grep,Task,TodoWrite,ExitPlanMode,EnterPlanMode,NotebookEdit,BashOutput,KillShell,Skill,SlashCommand,TaskCreate,TaskUpdate,TaskGet,TaskList,TaskOutput,TaskStop,AskUserQuestion,Monitor,PushNotification,EnterWorktree,ExitWorktree,CronCreate,CronDelete,CronList,RemoteTrigger,ListMcpResourcesTool,ReadMcpResourceTool,ToolSearch,mcp__searxng__search,mcp__searxng__fetch"
            ;;
        web)
            # Alias for 'code' — kept for backwards compatibility.
            allowlist_tools="Read,Edit,Write,Bash,Glob,Grep,Task,TodoWrite,ExitPlanMode,EnterPlanMode,NotebookEdit,BashOutput,KillShell,Skill,SlashCommand,TaskCreate,TaskUpdate,TaskGet,TaskList,TaskOutput,TaskStop,AskUserQuestion,Monitor,PushNotification,EnterWorktree,ExitWorktree,CronCreate,CronDelete,CronList,RemoteTrigger,ListMcpResourcesTool,ReadMcpResourceTool,ToolSearch,mcp__searxng__search,mcp__searxng__fetch"
            ;;
        all|off|none)
            allowlist_tools=""   # don't add the flag — full 274+ tool catalog passes through
            ;;
        *)
            echo "Unknown -allowlist value: $allowlist_preset" >&2
            echo "Try one of: minimal | code | all" >&2
            return 1
            ;;
    esac

    # Build args
    local args=(
        serve "$model"
        --port "$PORT"
        --continuous-batching
        --enable-auto-tool-choice
        --tool-call-parser "$tool_parser"
        --optimize-prompts
        --optimize-stub-tools
    )
    [[ -n "$reasoning_parser" ]] && args+=(--reasoning-parser "$reasoning_parser")
    [[ -n "$allowlist_tools" ]] && args+=(--optimize-tool-allowlist "$allowlist_tools")

    # Prefer the user's local vllm-mlx repo (with optimizer + thinking-gate
    # patches) over any system-wide install. Picking up the local copy means
    # our --optimize-prompts / --reasoning-parser flags actually exist.
    local pythonpath_prefix=""
    if [[ -d "$HOME/Dev/vllm-mlx/vllm_mlx" ]]; then
        pythonpath_prefix="PYTHONPATH=$HOME/Dev/vllm-mlx"
    fi

    local log="$LOG_DIR/$profile.log"

    cat <<INTRO
Starting profile: $profile
  model:            $model
  tool-parser:      $tool_parser
  reasoning-parser: ${reasoning_parser:-<none>}
  allowlist:        $allowlist_preset${allowlist_tools:+ ($allowlist_tools)}
  log:              $log

INTRO

    # Save active marker
    cat > "$ACTIVE" <<META
profile=$profile
model=$model
port=$PORT
log=$log
allowlist=$allowlist_preset
started=$(date -Iseconds)
META

    # Launch detached. PYTHONPATH prefix (if any) ensures we use the user's
    # local patched repo over any system vllm-mlx.
    cd "$HOME/Dev/vllm-mlx" 2>/dev/null || cd "$HOME"
    if [[ -n "$pythonpath_prefix" ]]; then
        nohup env $pythonpath_prefix vllm-mlx "${args[@]}" > "$log" 2>&1 &
    else
        nohup vllm-mlx "${args[@]}" > "$log" 2>&1 &
    fi
    local server_pid=$!
    disown $server_pid 2>/dev/null || true
    echo "server-pid=$server_pid"

    # Wait for ready. Total budget is 5 minutes for already-cached models, but
    # a fresh download can easily take longer — when we see "Fetching N files"
    # progress in the log, the deadline gets pushed out automatically.
    local STEP_S=5
    local BASE_TIMEOUT_S=300       # 5 min for load when weights already on disk
    local DOWNLOAD_GRACE_S=900     # +15 min while a download is actively running
    local deadline=$(( $(date +%s) + BASE_TIMEOUT_S ))
    local downloading_announced=0
    local ready=0

    echo "Waiting for model load (up to ${BASE_TIMEOUT_S}s; will extend if download is in progress)…"
    while :; do
        if grep -q "Application startup complete" "$log" 2>/dev/null; then
            ready=1
            break
        fi
        if grep -qE "ERROR|Traceback|address already in use" "$log" 2>/dev/null; then
            echo
            echo "✗ Server failed. Last 20 log lines:"
            tail -20 "$log"
            return 1
        fi
        # If a download is in progress, extend the deadline so we don't kill
        # ourselves mid-fetch.
        if grep -qE "Fetching [0-9]+ files: *[0-9]+%" "$log" 2>/dev/null && \
           ! grep -qE "Fetching [0-9]+ files: *100%" "$log" 2>/dev/null; then
            if [[ $downloading_announced -eq 0 ]]; then
                echo
                echo "  (download in progress — extending timeout by ${DOWNLOAD_GRACE_S}s)"
                downloading_announced=1
            fi
            deadline=$(( $(date +%s) + DOWNLOAD_GRACE_S ))
        fi
        if (( $(date +%s) >= deadline )); then
            break
        fi
        sleep "$STEP_S"
        printf "."
    done
    echo

    if [[ $ready -ne 1 ]]; then
        echo "⚠ Timed out waiting for model load."
        echo "  The server may still be loading — check:"
        echo "     tail -F $log"
        echo "     localclaude status"
        return 1
    fi

    echo "✓ Server ready at http://localhost:$PORT"
    print_connect "$model"
}

# ── List cached ───────────────────────────────────────────────────
list_cached() {
    echo "── Cached MLX models in ~/Models/ ──"
    if [[ ! -d "$HOME/Models" ]]; then
        echo "  (no ~/Models directory)"
        return 0
    fi
    find "$HOME/Models" -maxdepth 1 -type d -name "models--*" 2>/dev/null | sort | while read -r d; do
        local mid
        mid=$(basename "$d" | sed -e 's|^models--||' -e 's|--|/|')
        if find "$d/snapshots" -maxdepth 2 -name "*.safetensors" -print -quit 2>/dev/null | grep -q .; then
            local size
            size=$(du -sh "$d" 2>/dev/null | awk '{print $1}')
            printf "  %6s  %s\n" "$size" "$mid"
        fi
    done
}

# ── Restart shortcut ──────────────────────────────────────────────
do_restart() {
    if [[ ! -f "$ACTIVE" ]]; then
        echo "No last-active profile to restart." >&2
        echo "Pick one:  localclaude start <profile>" >&2
        return 1
    fi
    # shellcheck disable=SC1090
    source "$ACTIVE"
    do_start "$profile"
}

# ── Dispatch ──────────────────────────────────────────────────────
case "${1:-}" in
    ""|-h|--help|help) help ;;
    start)             shift; do_start "$@" ;;
    stop)              do_stop ;;
    restart)           do_restart ;;
    status)            do_status ;;
    list)              list_cached ;;
    doctor|check)      do_doctor ;;
    test)              do_test ;;
    *)
        echo "Unknown subcommand: $1" >&2
        help >&2
        exit 1
        ;;
esac
