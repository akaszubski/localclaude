# Optional environment overrides for the local-claude-code-mlx stack.
# Copy to .env (or add to your shell rc) and edit as needed.
# .env is gitignored so it stays per-machine.

# ─── HuggingFace model cache (this stack uses ~/Models, not ~/.cache) ─

# Where downloaded model weights live. ~/Models keeps them out of macOS's
# evictable .cache/, makes them easier to back up, and lets you NFS-share
# the same store across multiple Macs (M3 Ultra + M4 Max, etc.).
# `localclaude` checks $HOME/Models first via _is_model_cached().
HF_HUB_CACHE=$HOME/Models

# ─── localclaude knobs ────────────────────────────────────────────────

# Sister-component path overrides (auto-resolved from script location by
# default; only set these if you've moved things around).
# LOCALCLAUDE_WORKSPACE_DIR=/path/to/workspace
# LOCALCLAUDE_VLLM_MLX_DIR=/path/to/vllm-mlx
# LOCALCLAUDE_SEARXNG_MCP_DIR=/path/to/searxng-mcp

# SSD KV cache (default-on as of 2026-04-26). Set to "off" to disable.
# LOCALCLAUDE_SSD_CACHE_DIR=$HOME/.localclaude/ssd-cache
# LOCALCLAUDE_SSD_CACHE_MAX_GB=20

# Remote SSH endpoint for the coder-480 profile. Empty means coder-480
# won't auto-route; set on machines that have access to a 480B-capable Mac.
# LOCALCLAUDE_CODER_480_REMOTE=user@host

# Extra args appended verbatim to `vllm-mlx serve`. Used by the bench
# harness to A/B cache features; set per-shell when you want opt-in knobs.
# LOCALCLAUDE_EXTRA_VLLM_ARGS="--warm-prompts /path/to/seed.json --enable-mtp"

# ─── searxng-mcp knobs ────────────────────────────────────────────────

# Override the default SearXNG secret_key. The compose.yml reads this env
# var; if unset, falls back to a known-public placeholder
# (localclaude-searxng-default-change-me) which is fine for single-user
# loopback-only use but you should set your own for any non-trivial setup.
# SEARXNG_SECRET=$(openssl rand -hex 32)

# searxng-mcp HTTP backend (defaults to https://searxng.docker.orb.local on
# OrbStack; http://127.0.0.1:8080 on Docker Desktop or Colima).
# SEARXNG_URL=http://127.0.0.1:8080
# SEARXNG_TIMEOUT=30
# SEARXNG_VERIFY=0

# ─── bench harness knobs ──────────────────────────────────────────────

# Override the bundled vllm-mlx capture-server path used by Step 0.
# BENCH_CAPTURE_SERVER=/path/to/capture_server.py
